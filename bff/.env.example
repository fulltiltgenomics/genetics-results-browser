# standalone BFF (backend-for-frontend) configuration. export these vars before
# running `npm run bff:dev` (or rely on the defaults below). see refactor.md section 1.

# base URL of the upstream genetics-results-api, including the /api path segment.
# the BFF forwards /api/* here. defaults to the local API dev server.
GENETICS_API_URL=http://localhost:2000/api

# port the BFF listens on. the frontend's VITE_API_URL (dev) and the vite dev proxy
# both point at this port. defaults to 5000 (2000=API, 3000=vite, 4000=chat are taken).
BFF_PORT=5000
