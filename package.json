{
  "name": "genetics_browser",
  "version": "2024.0.1",
  "description": "genetics result browser",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "vite --host --port 3000",
    "build": "vite build",
    "serve": "vite preview --host",
    "bff": "tsx bff/server.ts",
    "bff:dev": "tsx watch bff/server.ts",
    "bff:test": "vitest run --config bff/vitest.config.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "jkarjala@broadinstitute.org",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/react": "^2.0.109",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@mui/icons-material": "^6.4.6",
    "@mui/lab": "^6.0.0-beta.29",
    "@mui/material": "^6.4.6",
    "@tanstack/react-query": "^5.66.11",
    "@tanstack/react-table": "^8.21.2",
    "ai": "^5.0.108",
    "axios": "^1.13.2",
    "chart.js": "^4.4.8",
    "crypto-js": "^4.2.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "export-to-csv": "^1.4.0",
    "express": "^4.22.2",
    "lz-string": "^1.5.0",
    "marked": "^18.0.0",
    "material-react-table": "^3.2.1",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^4.6.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.2.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/express": "^4.17.25",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "source-map-loader": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.2",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "nodemonConfig": {
    "watch": [
      "./static"
